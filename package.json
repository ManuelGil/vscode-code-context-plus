{
	"name": "vscode-code-context-plus",
	"displayName": "CodeContext+ - Navigate context directly from your code",
	"description": "See where context exists in your code and open related notes directly from any file or line.",
	"version": "1.0.0",
	"icon": "icon.png",
	"license": "MIT",
	"publisher": "imgildev",
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"sponsor": {
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"vscode": "^1.102.0",
		"node": ">=22.15.1"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"backlinks",
		"code context",
		"code navigation",
		"codebase",
		"context",
		"developer productivity",
		"developer tools",
		"documentation",
		"knowledge management",
		"knowledge",
		"linked notes",
		"links",
		"navigation",
		"notes",
		"software architecture"
	],
	"homepage": "https://github.com/ManuelGil/vscode-code-context-plus",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ManuelGil/vscode-code-context-plus.git"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/vscode-code-context-plus/issues"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"l10n": "./l10n",
	"files": [
		"out",
		"package*.json",
		"README.md",
		"LICENSE",
		"icon.png",
		"schemas",
		"l10n"
	],
	"contributes": {
		"configuration": {
			"type": "object",
			"title": "Code  Context Configuration",
			"properties": {
				"codeContextPlus.enable": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%codeContextPlus.enable.description%"
				},
				"codeContextPlus.notes.notesFolder": {
					"type": "string",
					"default": ".context/notes",
					"scope": "resource",
					"description": "%codeContextPlus.notes.notesFolder.description%"
				}
			}
		},
		"commands": [
			{
				"command": "codeContextPlus.changeWorkspace",
				"title": "%codeContextPlus.changeWorkspace.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.createProjectNote",
				"title": "%codeContextPlus.createProjectNote.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.openProjectNote",
				"title": "%codeContextPlus.openProjectNote.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.insertNoteLink",
				"title": "%codeContextPlus.insertNoteLink.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.goToNoteById",
				"title": "%codeContextPlus.goToNoteById.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.openLinkedNote",
				"title": "%codeContextPlus.openLinkedNote.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.openReference",
				"title": "%codeContextPlus.openReference.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.openBacklinks",
				"title": "%codeContextPlus.openBacklinks.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.openRelatedNotes",
				"title": "%codeContextPlus.openRelatedNotes.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.openContextForFile",
				"title": "%codeContextPlus.openContextForFile.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.openContextForLine",
				"title": "%codeContextPlus.openContextForLine.title%",
				"category": "CodeContext+"
			},
			{
				"command": "codeContextPlus.notesExplorer.refreshList",
				"title": "%codeContextPlus.notesExplorer.refreshList.title%",
				"category": "CodeContext+",
				"icon": "$(refresh)"
			}
		],
		"views": {
			"explorer": [
				{
					"id": "codeContextPlus.notesExplorer",
					"name": "%codeContextPlus.notesExplorer.title%",
					"when": "workspaceFolderCount > 0"
				}
			]
		},
		"menus": {
			"view/title": [
				{
					"command": "codeContextPlus.notesExplorer.refreshList",
					"when": "view == codeContextPlus.notesExplorer",
					"group": "navigation@1"
				}
			]
		},
		"jsonValidation": [
			{
				"fileMatch": ".vscode/settings.json",
				"url": "./schemas/config.schema.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm compile",
		"compile": "rimraf out && esbuild src/extension.ts --bundle --platform=node --target=node22 --format=cjs --external:vscode --outfile=out/extension.js --minify",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm compile && pnpm lint",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write --unsafe .",
		"test": "vscode-test",
		"l10n:check": "node scripts/check-l10n.js",
		"nls:check": "node scripts/check-nls.js",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/mocha": "^10.0.10",
		"@types/mustache": "^4.2.6",
		"@types/node": "^22.19.17",
		"@types/vscode": "^1.102.0",
		"@vscode/l10n-dev": "^0.0.35",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.28.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"mocha": "^11.7.5",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@supercharge/promise-pool": "^3.3.0",
		"fast-glob": "^3.3.3",
		"ignore": "^7.0.5",
		"mustache": "^4.2.0",
		"vscode-marketplace-client": "^1.2.1"
	},
	"pnpm": {
		"overrides": {
			"diff": "^8.0.3",
			"follow-redirects": "^1.16.0",
			"picomatch": "^2.3.2",
			"minimatch": "10.2.5",
			"serialize-javascript": "^7.0.5",
			"yaml": "^2.8.3"
		},
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
